<Window x:Class="WPF.ConfirmExitWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:p="clr-namespace:WPF.Properties"
        Title="{x:Static p:Resources.Msg_ConfirmExitTitle}"
        Width="420" Height="160"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{x:Static p:Resources.Msg_ConfirmExitText}"
                   TextWrapping="Wrap"
                   FontSize="14"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button x:Name="btnOk"
                    Content="{x:Static p:Resources.Common_Ok}"
                    Width="90" Height="28" Margin="0,0,8,0"
                    IsDefault="True"/>
            <Button x:Name="btnCancel"
                    Content="{x:Static p:Resources.Common_Cancel}"
                    Width="90" Height="28"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
