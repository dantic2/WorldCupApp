<Window x:Class="WPF.PlayerInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:p="clr-namespace:WPF.Properties"
        Title="{x:Static p:Resources.PlayerInfo_Title}"
        Width="420" Height="260"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="110"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border CornerRadius="8" ClipToBounds="True" Width="96" Height="96" BorderThickness="1" BorderBrush="#33000000">
            <Image x:Name="imgPlayer" Stretch="UniformToFill"/>
        </Border>

        <StackPanel Grid.Column="1" Margin="12,0,0,0">
            <TextBlock x:Name="txtName" FontSize="18" FontWeight="Bold" TextWrapping="Wrap"/>
            <TextBlock x:Name="txtMeta" Margin="0,6,0,0"/>
            <TextBlock x:Name="txtCaptain" Margin="0,2,0,0"/>
            <TextBlock x:Name="txtGoals" Margin="0,10,0,0" FontWeight="SemiBold"/>
            <TextBlock x:Name="txtYellow" Margin="0,2,0,0" FontWeight="SemiBold"/>

            <Button x:Name="btnClose"
                    Content="{x:Static p:Resources.Common_Close}"
                    Width="90" Height="28" Margin="0,14,0,0"
                    HorizontalAlignment="Left"/>
        </StackPanel>
    </Grid>
</Window>
