<Window x:Class="WPF.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF"
        xmlns:p="clr-namespace:WPF.Properties"
        mc:Ignorable="d"
        Title="{x:Static p:Resources.Settings_Title}"
        Height="280" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        KeyDown="SettingsWindow_KeyDown">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{x:Static p:Resources.Settings_Championship}" FontWeight="Bold"/>
        <ComboBox x:Name="cbChampionship" Grid.Row="1" Margin="0,6,0,10" Height="26" />

        <TextBlock Text="{x:Static p:Resources.Settings_Language}" Grid.Row="2" FontWeight="Bold"/>
        <ComboBox x:Name="cbLanguage" Grid.Row="3" Margin="0,6,0,10" Height="26" />

        <TextBlock Text="{x:Static p:Resources.Settings_Resolution}" Grid.Row="4" FontWeight="Bold"/>
        <ComboBox x:Name="cbWindowMode" Grid.Row="5" Margin="0,6,0,10" Height="26" />

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="btnOk"
                    Content="{x:Static p:Resources.Common_Confirm}"
                    Width="90" Height="28" Margin="0,0,8,0" 
                    IsDefault="True"/>
            <Button x:Name="btnCancel"
                    Content="{x:Static p:Resources.Common_Cancel}"
                    Width="90" Height="28"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>