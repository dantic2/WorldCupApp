<UserControl x:Class="WPF.PlayerCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="120" Height="54">
    <Border CornerRadius="8"
            Background="#EFFFFFFF"
            Padding="6"
            BorderBrush="#33000000"
            BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border CornerRadius="6" ClipToBounds="True" Width="36" Height="36" VerticalAlignment="Center">
                <Image x:Name="img" Stretch="UniformToFill"/>
            </Border>

            <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                <TextBlock x:Name="txtNumber" FontWeight="Bold" FontSize="12"/>
                <TextBlock x:Name="txtName" FontSize="12" TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
