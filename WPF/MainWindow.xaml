<Window x:Class="WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF"
        xmlns:p="clr-namespace:WPF.Properties"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Vertical" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="{x:Static p:Resources.Main_Team}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="cbTeams" Width="260" Height="26" DisplayMemberPath="DisplayName"/>

                <Button x:Name="btnTeamInfo" Content="Info" Width="70" Height="26" Margin="10,0,0,0"/>

                <Button x:Name="btnSettings" Content="{x:Static p:Resources.Settings_Title}" Width="90" Height="26" Margin="20,0,0,0"/>
            </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="{x:Static p:Resources.Main_Opponent}" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox x:Name="cbOpponents" Width="260" Height="26" DisplayMemberPath="Country"/>

            <Button x:Name="btnOpponentInfo" Content="Info" Width="70" Height="26" Margin="10,0,0,0"/>
        </StackPanel>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <TextBlock x:Name="txtScore" FontSize="18" FontWeight="Bold" />

                <TextBlock Text="{x:Static p:Resources.Main_Team}" FontWeight="Bold" Margin="0,12,0,6"/>
                <ListBox x:Name="lbPlayers" Height="260">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <DockPanel Margin="0,4">
                                <Image Width="44" Height="44" Margin="0,0,10,0"
                       Source="{Binding ImagePath}" Stretch="UniformToFill"/>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                    <TextBlock>
                        <Run Text="#"/>
                        <Run Text="{Binding ShirtNumber}"/>
                        <Run Text="  "/>
                        <Run Text="{Binding Position}"/>
                        <Run Text="  "/>
                        <Run Text="{Binding CaptainLabel}"/>
                                    </TextBlock>
                                </StackPanel>
                            </DockPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Text="{x:Static p:Resources.Main_StartingEleven}" FontWeight="Bold" Margin="0,14,0,6"/>

                <Grid x:Name="gridStartingEleven" MinHeight="520">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="420"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" x:Name="gridPitch" Margin="0,0,0,10">
                        <Grid.Background>
                            <ImageBrush ImageSource="/Images/pitch.jpg" Stretch="Uniform"/>
                        </Grid.Background>

                        <Border Width="2" Background="White" HorizontalAlignment="Center"/>

                        <Canvas x:Name="canvasPitch"/>
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Padding="6" Margin="0,0,10,0" Background="#10FFFFFF">
                            <StackPanel>
                                <TextBlock Text="{x:Static p:Resources.Main_SelectedTeam}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="spLeftLineup"/>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Padding="6" Margin="10,0,0,0" Background="#10FFFFFF">
                            <StackPanel>
                                <TextBlock Text="{x:Static p:Resources.Main_Opponent}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="spRightLineup"/>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
